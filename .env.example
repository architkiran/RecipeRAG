# ── OpenRouter Configuration ───────────────────────
# Sign up free at https://openrouter.ai/ and get your API key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── PostgreSQL Configuration ───────────────────────
# These must match the values in docker-compose.yml
POSTGRES_USER=reciperag
POSTGRES_PASSWORD=reciperag_dev_password
POSTGRES_DB=reciperag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Embedding Model ────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── LLM Model (OpenRouter free tier) ───────────────
# Check https://openrouter.ai/models for current free models
LLM_MODEL=mistralai/mistral-7b-instruct:free